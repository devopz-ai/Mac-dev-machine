
# ==============================================================================
# Mac Dev Machine Setup - Shell Configuration
# Added by: https://github.com/devopz-ai/Mac-dev-machine
# ==============================================================================

# ------------------------------------------------------------------------------
# Homebrew
# ------------------------------------------------------------------------------
if [[ -d "/opt/homebrew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
else
    eval "$(/usr/local/bin/brew shellenv)"
fi

# ------------------------------------------------------------------------------
# Python (pyenv)
# ------------------------------------------------------------------------------
# Pyenv manages multiple Python versions
# Commands:
#   pyenv versions          - List installed versions
#   pyenv install 3.12.0    - Install a version
#   pyenv global 3.12.0     - Set global default
#   pyenv local 3.11.0      - Set version for current directory
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv &> /dev/null; then
    eval "$(pyenv init -)"
    eval "$(pyenv virtualenv-init -)" 2>/dev/null || true
fi

# ------------------------------------------------------------------------------
# Node.js (nvm)
# ------------------------------------------------------------------------------
# NVM manages multiple Node.js versions
# Commands:
#   nvm ls                  - List installed versions
#   nvm install 20          - Install Node 20
#   nvm use 20              - Switch to Node 20
#   nvm alias default 20    - Set default version
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# ------------------------------------------------------------------------------
# Java
# ------------------------------------------------------------------------------
# JAVA_HOME is required by many Java tools
export JAVA_HOME=$(/usr/libexec/java_home 2>/dev/null || echo "")
if [[ -n "$JAVA_HOME" ]]; then
    export PATH="$JAVA_HOME/bin:$PATH"
fi

# ------------------------------------------------------------------------------
# Go
# ------------------------------------------------------------------------------
# Go workspace structure:
#   ~/go/bin/    - Compiled executables
#   ~/go/pkg/    - Package objects
#   ~/go/src/    - Source code (legacy, use modules instead)
export GOPATH="$HOME/go"
export GOROOT="$(brew --prefix go 2>/dev/null)/libexec"
export PATH="$GOPATH/bin:$PATH"

# ------------------------------------------------------------------------------
# Rust
# ------------------------------------------------------------------------------
# Rust toolchain installed via rustup
# Commands:
#   rustup update           - Update Rust
#   cargo build             - Build project
#   cargo run               - Run project
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# ------------------------------------------------------------------------------
# Ruby (rbenv)
# ------------------------------------------------------------------------------
# Rbenv manages multiple Ruby versions
# Commands:
#   rbenv versions          - List installed versions
#   rbenv install 3.3.0     - Install a version
#   rbenv global 3.3.0      - Set global default
if command -v rbenv &> /dev/null; then
    eval "$(rbenv init -)"
fi

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
export PATH="$(brew --prefix postgresql@16 2>/dev/null)/bin:$PATH"

# ------------------------------------------------------------------------------
# Google Cloud SDK
# ------------------------------------------------------------------------------
GCLOUD_PATH="$(brew --prefix 2>/dev/null)/share/google-cloud-sdk"
if [[ -d "$GCLOUD_PATH" ]]; then
    source "$GCLOUD_PATH/path.zsh.inc" 2>/dev/null || true
    source "$GCLOUD_PATH/completion.zsh.inc" 2>/dev/null || true
fi

# ------------------------------------------------------------------------------
# Kubernetes
# ------------------------------------------------------------------------------
alias k="kubectl"
if command -v kubectl &> /dev/null; then
    source <(kubectl completion zsh) 2>/dev/null || true
fi

# ------------------------------------------------------------------------------
# Zoxide (smarter cd)
# ------------------------------------------------------------------------------
# Usage: z <partial-path> instead of cd
if command -v zoxide &> /dev/null; then
    eval "$(zoxide init zsh)"
fi

# ------------------------------------------------------------------------------
# Starship Prompt
# ------------------------------------------------------------------------------
if command -v starship &> /dev/null; then
    eval "$(starship init zsh)"
fi

# ------------------------------------------------------------------------------
# FZF (Fuzzy Finder)
# ------------------------------------------------------------------------------
# Usage:
#   Ctrl+R  - Search command history
#   Ctrl+T  - Search files
#   Alt+C   - Search directories
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# ------------------------------------------------------------------------------
# CLI Aliases
# ------------------------------------------------------------------------------
# Better defaults
alias cat="bat --paging=never 2>/dev/null || cat"
alias ls="eza 2>/dev/null || ls"
alias ll="eza -la 2>/dev/null || ls -la"
alias tree="eza --tree 2>/dev/null || tree"
alias grep="grep --color=auto"

# Git shortcuts
alias g="git"
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"
alias gl="git pull"
alias gd="git diff"
alias gco="git checkout"
alias gb="git branch"
alias glog="git log --oneline --graph --decorate"

# Docker shortcuts
alias d="docker"
alias dc="docker compose"
alias dps="docker ps"
alias di="docker images"

# Navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# Safety
alias rm="rm -i"
alias cp="cp -i"
alias mv="mv -i"

# ------------------------------------------------------------------------------
# AI Tools - API Keys
# ------------------------------------------------------------------------------
# Uncomment and add your API keys:
# export OPENAI_API_KEY="your-key-here"
# export ANTHROPIC_API_KEY="your-key-here"
# export GOOGLE_API_KEY="your-key-here"

# ------------------------------------------------------------------------------
# Custom Functions
# ------------------------------------------------------------------------------

# Create directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract any archive
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"     ;;
            *.tar.gz)    tar xzf "$1"     ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.rar)       unrar x "$1"     ;;
            *.gz)        gunzip "$1"      ;;
            *.tar)       tar xf "$1"      ;;
            *.tbz2)      tar xjf "$1"     ;;
            *.tgz)       tar xzf "$1"     ;;
            *.zip)       unzip "$1"       ;;
            *.Z)         uncompress "$1"  ;;
            *.7z)        7z x "$1"        ;;
            *)           echo "'$1' cannot be extracted" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Quick HTTP server
serve() {
    local port="${1:-8000}"
    python3 -m http.server "$port"
}

# ------------------------------------------------------------------------------
# Local customizations
# ------------------------------------------------------------------------------
# Add your own customizations in ~/.zshrc.local
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
